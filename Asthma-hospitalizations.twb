    <dashboard enable-sort-zone-taborder='true' name='Data Source'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone forceUpdate='true' h='77625' id='3' type-v2='text' w='81900' x='8100' y='11125'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='16'>Data Sources</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The initiative makes use of information from three main sources: </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>1.     CDC Asthma Hospitalization Data </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Centers for Disease Control and Prevention (CDC)</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Contains annual asthma hospitalization rates by state and county across the U.S., providing insights into regional public health trends related to asthma.</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
            <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://data.cdc.gov/Environmental-Health/Asthma-Hospitalization-Rates-by-State/9n68-gwzk&amp;quot;' underline='true'>https://data.cdc.gov/Environmental-Health/Asthma-Hospitalization-Rates-by-State/9n68-gwzk</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>2.     USDA County-Level Population Data</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Department of Agriculture (USDA) – Economic Research Service</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Provides estimates of population by U.S. County, enabling normalization of health data (e.g., calculating per capita asthma hospitalization rates).</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
            <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://www.ers.usda.gov/data-products/county-level-data-sets/county-level-data-sets-download-data&amp;quot;' underline='true'>https://www.ers.usda.gov/data-products/county-level-data-sets/county-level-data-sets-download-data</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>3.     EPA Air Quality System (AQS) Data</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Environmental Protection Agency (EPA)</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Provides annual air pollution metrics by county (e.g., PM2.5, ozone), enabling environmental analysis of asthma triggers across geographic areas.</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
            <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://aqs.epa.gov/aqsweb/airdata/download_files.html&amp;quot;' underline='true'>https://aqs.epa.gov/aqsweb/airdata/download_files.html</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>4.     ACS Selected Economic Characteristics Data (American Community Survey)</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Census Bureau – American Community Survey (ACS)</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Includes state- and county-level economic indicators such as employment, income, poverty, and insurance coverage. Used to analyze socioeconomic correlations with asthma hospitalization trends.</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
            <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://data.census.gov/table?q=DP03&amp;quot;' underline='true'>https://data.census.gov/table?q=DP03</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The datasets were organized and merged in Tableau through relationships founded on FIPS codes and Year. These sources were chosen for their reliability and extensive coverage across different states and periods, enabling a significant longitudinal comparison. </run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='700' minheight='700' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='7' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='98000' id='6' param='vert' type-v2='layout-flow' w='98400' x='800' y='1000'>
                <zone forceUpdate='true' h='77625' id='3' type-v2='text' w='81900' x='8100' y='11125'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='16'>Data Sources</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The initiative makes use of information from three main sources: </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>1.     CDC Asthma Hospitalization Data </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Centers for Disease Control and Prevention (CDC)</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Contains annual asthma hospitalization rates by state and county across the U.S., providing insights into regional public health trends related to asthma.</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
                    <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://data.cdc.gov/Environmental-Health/Asthma-Hospitalization-Rates-by-State/9n68-gwzk&amp;quot;' underline='true'>https://data.cdc.gov/Environmental-Health/Asthma-Hospitalization-Rates-by-State/9n68-gwzk</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>2.     USDA County-Level Population Data</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Department of Agriculture (USDA) – Economic Research Service</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Provides estimates of population by U.S. County, enabling normalization of health data (e.g., calculating per capita asthma hospitalization rates).</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
                    <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://www.ers.usda.gov/data-products/county-level-data-sets/county-level-data-sets-download-data&amp;quot;' underline='true'>https://www.ers.usda.gov/data-products/county-level-data-sets/county-level-data-sets-download-data</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>3.     EPA Air Quality System (AQS) Data</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Environmental Protection Agency (EPA)</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Provides annual air pollution metrics by county (e.g., PM2.5, ozone), enabling environmental analysis of asthma triggers across geographic areas.</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
                    <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://aqs.epa.gov/aqsweb/airdata/download_files.html&amp;quot;' underline='true'>https://aqs.epa.gov/aqsweb/airdata/download_files.html</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>4.     ACS Selected Economic Characteristics Data (American Community Survey)</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Source: U.S. Census Bureau – American Community Survey (ACS)</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Description: Includes state- and county-level economic indicators such as employment, income, poverty, and insurance coverage. Used to analyze socioeconomic correlations with asthma hospitalization trends.</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Access: </run>
                    <run auto-url='true' fontcolor='#0068da' fontname='Times New Roman' fontsize='12' hyperlink='tabdoc:load-url url=&amp;quot;https://data.census.gov/table?q=DP03&amp;quot;' underline='true'>https://data.census.gov/table?q=DP03</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Æ </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The datasets were organized and merged in Tableau through relationships founded on FIPS codes and Year. These sources were chosen for their reliability and extensive coverage across different states and periods, enabling a significant longitudinal comparison. </run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{C3D30B35-7D0B-4CC0-9903-B932AA0A05BE}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='Research Questions'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone forceUpdate='true' h='82125' id='3' type-v2='text' w='63900' x='17500' y='8125'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='22'>Research Questions</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The motivation behind this project is rooted in a growing public health concern. Asthma affects millions of Americans, and environmental factors like air quality play a critical role in triggering attacks.</run>
            <run>Æ&#10;&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>1. How do asthma hospitalization rates vary across U.S. counties?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>2. Do urban–rural classifications predict differences in hospitalization rates?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>3. Is there a relationship between air pollution levels (PM2.5, ozone) and asthma hospitalizations?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>4. How do socioeconomic factors (income, poverty, insurance coverage) relate to asthma hospitalization rates?</run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='700' minheight='700' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='21' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='98000' id='20' param='vert' type-v2='layout-flow' w='98400' x='800' y='1000'>
                <zone forceUpdate='true' h='82125' id='3' type-v2='text' w='63900' x='17500' y='8125'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='22'>Research Questions</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>The motivation behind this project is rooted in a growing public health concern. Asthma affects millions of Americans, and environmental factors like air quality play a critical role in triggering attacks.</run>
                    <run>Æ&#10;&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>1. How do asthma hospitalization rates vary across U.S. counties?</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>2. Do urban–rural classifications predict differences in hospitalization rates?</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>3. Is there a relationship between air pollution levels (PM2.5, ozone) and asthma hospitalizations?</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>4. How do socioeconomic factors (income, poverty, insurance coverage) relate to asthma hospitalization rates?</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{01C89454-56D4-40DE-B949-DBE24651B358}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='Title'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone forceUpdate='true' h='73000' id='3' type-v2='text' w='71000' x='16300' y='15000'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='28'>Asthma Hospitalization in the United States</run>
            <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Ananya Gullapally</run>
            <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman'>This project analyzes county-level asthma hospitalization rates across the United States in 2023 to identify geographic disparities and examine potential environmental and socioeconomic drivers. The analysis explores differences by urban–rural classification, assesses associations with air pollution levels (PM2.5 and ozone), and evaluates the relationship between poverty and hospitalization rates. The dashboard integrates spatial mapping, distribution analysis, regression modeling, and parameter-driven interactivity to support exploratory and comparative analysis. </run>
            <run fontalignment='1'>Æ&#10;&#10;&#10;&#10;&#10;</run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='700' minheight='700' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='21' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='98000' id='20' param='vert' type-v2='layout-flow' w='98400' x='800' y='1000'>
                <zone forceUpdate='true' h='73000' id='3' type-v2='text' w='71000' x='16300' y='15000'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='28'>Asthma Hospitalization in the United States</run>
                    <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Ananya Gullapally</run>
                    <run fontalignment='1'>Æ&#10;&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman'>This project analyzes county-level asthma hospitalization rates across the United States in 2023 to identify geographic disparities and examine potential environmental and socioeconomic drivers. The analysis explores differences by urban–rural classification, assesses associations with air pollution levels (PM2.5 and ozone), and evaluates the relationship between poverty and hospitalization rates. The dashboard integrates spatial mapping, distribution analysis, regression modeling, and parameter-driven interactivity to support exploratory and comparative analysis. </run>
                    <run fontalignment='1'>Æ&#10;&#10;&#10;&#10;&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{011570FF-B128-43E2-97D3-9507DF91F886}' />
    </dashboard>
